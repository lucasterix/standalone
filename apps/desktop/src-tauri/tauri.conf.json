{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kontoklar",
  "version": "0.1.0",
  "identifier": "de.froehlichdienste.kontoklar",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kontoklar",
        "url": "https://kontoklar.froehlichdienste.de/login/",
        "width": 1320,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
